{
  "name": "nirs4all-ui",
  "version": "0.1.0",
  "description": "Shared React UI components and pure view-model helpers for nirs4all apps.",
  "type": "module",
  "license": "(CECILL-2.1 OR AGPL-3.0-or-later)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GBeurier/nirs4all-ui.git"
  },
  "private": false,
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./score": {
      "types": "./dist/score/index.d.ts",
      "import": "./dist/score/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
